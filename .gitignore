# Python
__pycache__/
*.py[cod]
venv/
.venv/

# Environment
.env
.flaskenv

# Databases
*.sqlite3

# Eggs / build artifacts
*.egg-info/
dist/
build/

# IDEs
.vscode/
.idea/
*.swp

# Minutes parse cache — populated by scripts/backfill_vote_context.py
data/minutes_cache/
.DS_Store

# Superpowers session scratch (brainstorm mockups, server pid/log)
.superpowers/

# Claude Code — user-local settings and worktree scratch dirs
# Team-level .claude/settings.json and .claude/agents/ remain trackable.
.claude/settings.local.json
.claude/worktrees/

# Deploy-time scratch — `scripts/deploy.sh` writes the current HEAD SHA
# into this file so the Dockerfile can COPY it into /app/COMMIT_SHA.
# Railway CLI excludes .git from uploads, so this is the only path
# for getting the build's commit hash into the image.
COMMIT_SHA
