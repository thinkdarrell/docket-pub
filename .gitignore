# Python
__pycache__/
*.py[cod]
venv/
.venv/

# Environment
.env
.flaskenv

# Databases
*.sqlite3

# Eggs / build artifacts
*.egg-info/
dist/
build/

# IDEs
.vscode/
.idea/
*.swp

# Minutes parse cache — populated by scripts/backfill_vote_context.py
data/minutes_cache/
.DS_Store

# Superpowers session scratch (brainstorm mockups, server pid/log)
.superpowers/

# Claude Code — user-local settings and worktree scratch dirs
# Team-level .claude/settings.json and .claude/agents/ remain trackable.
.claude/settings.local.json
.claude/worktrees/

# NOTE: `scripts/deploy.sh` writes a `COMMIT_SHA` scratch file at the
# repo root and cleans it up after `railway up`. It is intentionally
# NOT gitignored — Railway CLI honors .gitignore for uploads, and a
# gitignored COMMIT_SHA would be excluded from the build context (which
# is what made the first wrapper deploy stamp "unknown"). If the wrapper
# crashes mid-deploy and leaves a stale COMMIT_SHA, it will show up in
# `git status` so you can `rm` it before the next commit.
