# Database
DATABASE_URL=postgresql://docket:docket_dev@localhost:5432/docket_db

# Flask
FLASK_APP=docket.web:create_app()
FLASK_ENV=development
SECRET_KEY=generate-a-secure-key-here

# Domain
DOMAIN_NAME=docket.pub

# AI pipeline
ANTHROPIC_API_KEY=
AI_ITEM_MODEL=claude-haiku-4-5-20251001
AI_MEETING_MODEL=claude-sonnet-4-6
AI_DAILY_BUDGET_USD=10
AI_MAX_BATCH_SIZE=200

